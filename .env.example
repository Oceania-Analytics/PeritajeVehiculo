# ──────────────────────────────────────────────────────────────────────────────
# OceanIA PeritajeVehiculo — Environment Variables Template
# Copy this file to .env.local for local development,
# or supply these values as Docker environment variables / secrets.
# NEVER commit real secrets to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application Auth ──────────────────────────────────────────────────────────
# JWT signing secret — generate with: openssl rand -base64 32
SESSION_SECRET=REPLACE_WITH_SECURE_RANDOM_BASE64_STRING

# Predefined login credentials
APP_USERNAME=alfredo
# bcrypt hash of the password (cost factor >= 12). Generate with:
#   node -e "const b=require('bcryptjs'); b.hash('yourpassword',12).then(h=>console.log(h))"
APP_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH

# ── Next.js Frontend ──────────────────────────────────────────────────────────
# URL of the Next.js app (used for internal redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# URL of the Python backend (visible to the browser for API calls)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Node environment (development | production)
NODE_ENV=development

# ── Python Backend / Ollama ───────────────────────────────────────────────────
# Base URL of the Ollama service
OLLAMA_URL=https://ollama.com

# Optional API key for authenticated Ollama deployments
OLLAMA_API_KEY=

# Model name to use for vehicle analysis
OLLAMA_MODEL=gemma4:31b-cloud

# Comma-separated list of allowed CORS origins for the FastAPI backend
CORS_ORIGINS=http://localhost:3000,http://frontend:3000
